<Bindings>
	<Binding name="JTE_ITEMRACK_SET_TOGGLE" header="JTE_BINDINGS">
		JTE_ItemrackSetToggle();
	</Binding>

	<Binding name="JTE_TRINKETMENU_TOGGLE">
		JTE_TrinketMenuToggle();
	</Binding>

	<Binding name="JTE_DPSMATE_MAIN_TOGGLE">
		JTE_DPSMateToggleDPS();
	</Binding>

	<Binding name="JTE_DPSMATE_OTHER_TOGGLE">
		JTE_DPSMateToggleAll();
	</Binding>

	<Binding name="JTE_COMBATLOG_TOGGLE">
		JTE_CombatLog();
	</Binding>
	
	<Binding name="JTE_NAME_TOGGLE">
		JTE_NameToggle();
	</Binding>
	
	<Binding name="JTE_TRADE">
		InitiateTrade("target");
	</Binding>
		
	<Binding name="JTE_INSPECT">
		InspectUnit("target");
	</Binding>

	<Binding name="JTE_LEAVEPARTY">
		LeaveParty();
	</Binding>

</Bindings>